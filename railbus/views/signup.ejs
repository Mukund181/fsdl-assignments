<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - RailBus</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f4f4; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .form-container { background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); width: 100%; max-width: 400px; }
        h2 { text-align: center; color: #333; margin-bottom: 20px; }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; color: #666; }
        .form-group input, .form-group select { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
        .btn-submit { width: 100%; padding: 12px; border: none; border-radius: 4px; background: #007bff; color: white; font-size: 16px; cursor: pointer; transition: background 0.3s; }
        .btn-submit:hover { background: #0056b3; }
        .footer-link { text-align: center; margin-top: 15px; font-size: 14px; }
        .footer-link a { color: #007bff; text-decoration: none; }
    </style>
</head>
<body>
    <div class="form-container">
        <h2>RailBus Registration</h2>
        <form action="/signup" method="POST">
            <div class="form-group">
                <label for="role">Register as:</label>
                <select name="role" id="role" onchange="toggleCompany(this.value)">
                    <option value="customer">Customer</option>
                    <option value="employee">Company Employee</option>
                    <option value="infrastructure_manager">Infrastructure Manager</option>
                </select>
            </div>
            <div class="form-group">
                <label for="username">Username</label>
                <input type="text" name="username" id="username" required>
            </div>
            <div class="form-group" id="companyField" style="display: none;">
                <label for="companyName">Company Name</label>
                <input type="text" name="companyName" id="companyName">
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" name="password" id="password" required>
            </div>
            <button type="submit" class="btn-submit">Sign Up</button>
        </form>
        <div class="footer-link">
            Already have an account? <a href="/login">Login here</a>
        </div>
    </div>
    <script>
        function toggleCompany(role) {
            const companyField = document.getElementById('companyField');
            if (role === 'employee' || role === 'infrastructure_manager') {
                companyField.style.display = 'block';
            } else {
                companyField.style.display = 'none';
            }
        }
    </script>
</body>
</html>
